<resources>
    <style name="SplashTheme" parent="android:style/Theme.Material.Light.NoActionBar">
        <item name="android:windowSplashScreenBackground">@color/kd_white</item>
        <item name="android:windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="android:statusBarColor">@color/kd_white</item>
        <item name="android:navigationBarColor">@color/kd_white</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="android:windowLightNavigationBar">true</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
    </style>
</resources>
